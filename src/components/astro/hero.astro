---
import { WaveTechBackground } from "../react/waves";
import { GradientText } from "../react/react-bits";
import { ChevronDown } from "lucide-react";
---

<section
  id="home"
  class="relative flex flex-col justify-center items-center min-h-screen text-neutral-900 dark:text-neutral-100 px-6"
>
  <div class="text-center z-10 text-neutral-900 font-inter flex flex-col gap-4">
    <div class="flex flex-col gap-4">
      <p
        class="animate-hero-fade-in font-bold font-permanent max-lg:text-6xl text-9xl text-shadow-2xs tracking-tight leading-tight italic text-neutral-900 dark:text-neutral-200"
      >
        relancio borges.
      </p>

      <p
        class="animate-hero-fade-in [animation-delay:200ms] opacity-0 font-inter italic text-2xl md:text-2xl font-light tracking-tight w-full dark:text-neutral-200"
      >
        engenheiro de computação, <span class="italic">dev fullstack</span> &<br />
        entusiasta de tecnologia
      </p>

      <p
        class="animate-hero-fade-in [animation-delay:400ms] opacity-0 text-neutral-800 font-inter italic dark:text-neutral-300 text-lg max-w-2xl mx-auto"
      >
        Transformo{" "}
        <GradientText
          client:idle
          className="font-semibold inline"
          colors={["#737373", "#222", "#737373"]}
        >
          ideias
        </GradientText>{" "}
        em soluções digitais com um toque criativo e tecnologia de ponta.
      </p>
    </div>
  </div>
  <WaveTechBackground client:idle />
  <div
    class="absolute bottom-15 max-sm:bottom-0 animate-hero-fade-in [animation-delay:600ms] opacity-0"
  >
    <a href="#about" aria-label="Ir para seção Sobre">
      <ChevronDown
        class="animate-hero-bounce"
        size={44}
      />
    </a>
  </div>
</section>

